# EcoRoute Engine — environment variable template
# Copy to .env and fill in real values. Never commit .env.

# Server
PORT=3000
NODE_ENV=development
APP_NAME=EcoRoute Engine
API_PREFIX=/api/v1

# Database (PostgreSQL + PostGIS)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ecoroute_db
DATABASE_USER=ecoroute_user
DATABASE_PASSWORD=change_me_in_production
DATABASE_URL=postgresql://ecoroute_user:change_me_in_production@localhost:5432/ecoroute_db

# JWT
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# OSRM (route optimization)
OSRM_BASE_URL=http://localhost:5000
OSRM_TIMEOUT_MS=5000

# Offline / feature flags
OFFLINE_MODE=true
ENABLE_EXTERNAL_APIS=false
ENABLE_NOTIFICATIONS=false
ENABLE_EMAIL=false
ENABLE_SMS=false
ENABLE_QUEUE=false

# Logging
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# Frontend
FRONTEND_URL=http://localhost:3000

# Security
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
